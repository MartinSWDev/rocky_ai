# Rocky secrets — copy to .env and fill in. NEVER commit .env.
#
# Create a Jira API token at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_USERNAME=you@example.com
JIRA_API_TOKEN=your_atlassian_api_token_here

# Optional shared secret. If set, the server requires it on every query and the
# client/dashboard must present it. Use a long random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be identical on the PC and the Mac.
# ROCKY_AUTH_TOKEN=
