<?xml version="1.0" encoding="UTF-8"?>
<!-- Auto-starts the rocky_say (Coqui XTTS) persistent TTS server at login.
     Template: __HOME__ is substituted by install_launchd.sh. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rocky.tts</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/rocky_say</string>
        <string>--server</string>
        <string>start</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__HOME__/.rocky_say/tts.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.rocky_say/tts.err.log</string>
</dict>
</plist>
